# Django
DEBUG=True
SECRET_KEY=change-me

# PostgreSQL (required)
# Render sets DATABASE_URL automatically — use this for local dev:
# DATABASE_URL=postgresql://libra_admin:your-password@localhost:5432/libra_db
PGDATABASE=libra_db
PGUSER=libra_admin
PGPASSWORD=your-password
PGHOST=localhost
PGPORT=5432
# DB_CONN_MAX_AGE=60

# Email (optional — console backend used if EMAIL_HOST is empty)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=your-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Library <no-reply@example.com>

# Allowed hosts (comma-separated)
# ALLOWED_HOSTS=127.0.0.1,localhost,your-domain.kz
