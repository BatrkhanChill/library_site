msgstr "Қазірдің өзінде аккаунтыңыз бар ма?"

msgid "Усть-Каменогорск, ул. Бажова, 68"
msgstr "Өскемен, Бажов көшесі, 68"

msgid "Усть-Каменогорский колледж экономики и техники. Все права защищены."
msgstr "Өскемен экономика және техника колледжі. Барлық құқықтар қорғалған."

msgid "Учебник по математике"
msgstr "Математика оқулығы"

msgid "Целевая группа"
msgstr "Мақсатты топ"

msgid "Электронная библиотека колледжа экономики и техники"
msgstr "Экономика және техника колледжінің электрондық кітапханасы"

msgid "из"
msgstr "дан"
