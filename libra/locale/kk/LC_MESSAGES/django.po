msgid "PDF файлов"
msgstr "PDF файлдары"

msgid "Автору"
msgstr "Автор бойынша"

msgid "Авторы"
msgstr "Авторлар"

msgid "Админ-панель"
msgstr "Әкімші панелі"

msgid "Библиотека УК-ЭТК"
msgstr "УК-ЭТК кітапханасы"

msgid "Библиотека колледжа"
msgstr "Колледж кітапханасы"

msgid ""
"Виртуальная библиотека УК-ЭТК. Учебная литература, электронные ресурсы и "
"материалы онлайн."
msgstr ""
"УК-ЭТК виртуалды кітапханасы. Оқу әдебиеті, электрондық ресурстар және "
"онлайн материалдар."

msgid "Войдите, чтобы сохранить"
msgstr "Сақтау үшін кіріңіз"

msgid "Войти"
msgstr "Кіру"

msgid "Всего экземпляров:"
msgstr "Жалпы даналар:"

msgid "Вход - Библиотека Колледжа"
msgstr "Кіру - Колледж кітапханасы"

msgid "Выберите направление обучения"
msgstr "Оқуға бағыт таңдаңыз"

msgid "Выйти"
msgstr "Шығу"

msgid "Главная"
msgstr "Басты бет"

msgid "Главная - Библиотека колледжа"
msgstr "Басты бет - Колледж кітапханасы"

msgid "Году издания"
msgstr "Жылы бойынша"

msgid "Дата добавления"
msgstr "Қосылған күні"

msgid "Добро пожаловать"
msgstr "Қош келдіңіз"

msgid "Доступно сейчас"
msgstr "Қолжетімді қазір"

