msgstr "Кітап іздеу"

msgid "Поиск книги, автора или темы..."
msgstr "Кітапты, авторды немесе тақырыпты іздеңіз..."

msgid ""
"Поиск нужных книг, отслеживание историй и доступ к учебным ресурсам в одном "
"месте."
msgstr ""
"Қажетті кітаптарды табу, тарихты бақылау және оқу ресурстарына бір жерде қол"
" жеткізу."

msgid "Последние поступления"
msgstr "Соңғы келулер"

msgid "Похожие книги"
msgstr "Ұқсас кітаптар"

msgid "Практическое руководство по IT"
msgstr "IT практикалық нұсқаулығы"

msgid "Применить фильтры"
msgstr "Фильтрлерді қолдану"

msgid "Профиль"
msgstr "Профиль"

msgid "Разделы"
msgstr "Бөлімдер"

msgid "Регистрация"
msgstr "Тіркелу"

msgid "Регистрация - Библиотека Колледжа"
msgstr ""

msgid "Свежие книги, которые уже доступны для чтения и загрузки."
msgstr "Оқу және жүктеу үшін қолжетімді жаңа кітаптар."

msgid "Скачать PDF"
msgstr "PDF жүктеу"

msgid "Современные методики преподавания"
msgstr "Қазіргі оқыту әдістері"

msgid "Создать аккаунт"
msgstr "Аккаунт жасау"

msgid "Сортировать по"
msgstr "Сұрыптау бойынша"

msgid "Специализация"
